PORT=5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=college_achievements
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Bot API
BOT_API_KEY=your-bot-api-key-here

# Telegram Bot token (same as in bot/.env)
BOT_TOKEN=your_telegram_bot_token_here
